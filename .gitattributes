# Normalize line endings to LF in the repo for all text files.
# Keeps diffs stable across Windows/macOS/Linux checkouts.
* text=auto eol=lf

# Explicit binary types (never normalize / never diff as text)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.mp3 binary
*.wav binary
*.ogg binary
*.woff binary
*.woff2 binary
